# Supabase
SUPABASE_URL= 
SUPABASE_SERVICE_KEY=

# KimiAI — OpenAI-compatible, use openai SDK with base_url override
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# TokenRouter — OpenAI-compatible entry point; routes to Kimi / SenseNova etc.
# Pass model="moonshot-v1-128k" for code, model="sensenova-u1" for image
TOKENROUTER_API_KEY= 
TOKENROUTER_API_BASE=https://tokenrouter.io/v1

# BrightData — Web Scraper API
# POST https://api.brightdata.com/request  body: { "url": "...", "format": "markdown" }
BRIGHTDATA_API_KEY= 

# Daytona — sandbox execution
# Flow: POST /sandbox → POST /sandbox/{id}/files → POST /sandbox/{id}/exec → DELETE /sandbox/{id}
DAYTONA_API_KEY=
DAYTONA_API_BASE=https://app.daytona.io/api

# Nosana — distributed GPU for ML training jobs (used instead of Daytona when task_type=train)
# POST /job  body: { "image": "...", "script": "...", "gpu": true }  then poll GET /job/{id}
NOSANA_API_KEY=
NOSANA_API_BASE=https://api.nosana.io/v1

# SenseNova — image generation, OpenAI-compatible images.generate()
# Model: nova-ptx-xl  triggered when prompt contains "generate image" / "mockup" / "diagram"
SENSENOVA_API_KEY=
SENSENOVA_API_BASE=https://api.sensenova.cn/v1
SENSENOVA_MODEL=nova-ptx-xl
