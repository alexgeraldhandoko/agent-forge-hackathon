AI_WORKSPACE_STORE=redis
REDIS_URL=redis://localhost:6379/0

# Model gateway: tokenrouter or kimi.
# If MODEL_GATEWAY is omitted, the backend uses TokenRouter when TOKENROUTER_API_KEY is set;
# otherwise it falls back to direct Kimi.
MODEL_GATEWAY=tokenrouter
AI_WORKSPACE_CODING_MODEL=kimi-k2.7-code
AI_WORKSPACE_WEB_MODEL=kimi-k2.7-code
AI_WORKSPACE_GENERAL_MODEL=kimi-k2.6

# TokenRouter OpenAI-compatible gateway.
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
# Optional: force all model calls through one TokenRouter model/channel.
# If omitted, the backend sends the routed model above.
TOKENROUTER_MODEL=
TOKENROUTER_TIMEOUT_SECONDS=60

# Bright Data web research. SERP is required for web/current-info prompts.
# Unlocker is optional; when set, the backend fetches top result page excerpts too.
BRIGHTDATA_API_KEY=
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_UNLOCKER_ZONE=
BRIGHTDATA_ENDPOINT=https://api.brightdata.com/request
BRIGHTDATA_COUNTRY=us
BRIGHTDATA_LANGUAGE=en
BRIGHTDATA_TIMEOUT_SECONDS=45
BRIGHTDATA_PAGE_EXCERPT_CHARS=3000

# Direct Kimi fallback. Use either key name. Do not commit real keys.
MOONSHOT_API_KEY=
# KIMI_API_KEY=

KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.7-code
KIMI_TIMEOUT_SECONDS=60
